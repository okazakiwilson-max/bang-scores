<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lake E BANG Scores</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #c49a1a;
    --gold-bright: #e8b420;
    --bg: #1a1612;
    --surface: #221e1a;
    --surface2: #2a2520;
    --border: rgba(196,154,26,0.12);
    --text: #c8bfb0;
    --text-dim: rgba(200,191,176,0.4);
    --green: #4a9e6b;
    --red: #b85555;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--text); font-family:'DM Sans',sans-serif; min-height:100vh; }
  header { padding:24px 40px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
  .badge { width:42px; height:42px; background:transparent; border:1px solid var(--gold); border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Bebas Neue',sans-serif; color:var(--gold); font-size:15px; letter-spacing:1px; flex-shrink:0; }
  .logo { display:flex; align-items:center; gap:14px; }
  h1 { font-family:'Bebas Neue',sans-serif; font-size:1.9rem; color:var(--text); letter-spacing:3px; line-height:1; }
  h1 span { display:block; font-size:0.72rem; color:var(--gold); font-family:'DM Mono',monospace; letter-spacing:4px; opacity:0.7; font-weight:400; }
  .hdr-right { font-family:'DM Mono',monospace; font-size:0.62rem; color:var(--text-dim); letter-spacing:2px; text-align:right; text-transform:uppercase; }
  .main { padding:28px 40px; max-width:1400px; margin:0 auto; }
  .selector-row { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:26px; align-items:center; }
  .sel-label { font-family:'DM Mono',monospace; font-size:0.6rem; letter-spacing:3px; text-transform:uppercase; color:var(--text-dim); margin-right:4px; }
  .pbtn { background:var(--surface); border:1px solid rgba(196,154,26,0.15); color:var(--text-dim); font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:500; padding:6px 12px; border-radius:4px; cursor:pointer; transition:all 0.15s; }
  .pbtn:hover { border-color:rgba(196,154,26,0.4); color:var(--text); }
  .pbtn.active { background:var(--surface2); border-color:var(--gold); color:var(--gold-bright); font-weight:600; }
  .chart-section { background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:24px 24px 18px; margin-bottom:18px; }
  .chart-title { font-family:'Bebas Neue',sans-serif; font-size:1.4rem; letter-spacing:2px; color:var(--text); margin-bottom:2px; }
  .chart-sub { font-family:'DM Mono',monospace; font-size:0.58rem; letter-spacing:2px; color:var(--text-dim); margin-bottom:20px; text-transform:uppercase; }
  .chart-wrap { position:relative; height:260px; }
  .stats-bar { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:18px; }
  .stat-card { background:var(--surface); border:1px solid var(--border); border-radius:6px; padding:14px 18px; }
  .stat-label { font-family:'DM Mono',monospace; font-size:0.56rem; letter-spacing:3px; text-transform:uppercase; color:var(--text-dim); margin-bottom:5px; }
  .stat-val { font-family:'Bebas Neue',sans-serif; font-size:1.9rem; color:var(--gold-bright); line-height:1; }
  .stat-sub { font-family:'DM Mono',monospace; font-size:0.56rem; color:var(--text-dim); margin-top:3px; }
  .log-section { background:var(--surface); border:1px solid var(--border); border-radius:8px; overflow:hidden; }
  .log-hdr { padding:13px 22px; border-bottom:1px solid var(--border); }
  .log-title { font-family:'Bebas Neue',sans-serif; font-size:1rem; letter-spacing:2px; color:var(--text); }
  table { width:100%; border-collapse:collapse; }
  th { font-family:'DM Mono',monospace; font-size:0.56rem; letter-spacing:3px; text-transform:uppercase; color:var(--text-dim); padding:9px 16px; text-align:left; border-bottom:1px solid var(--border); background:rgba(0,0,0,0.2); }
  td { font-family:'DM Mono',monospace; font-size:0.78rem; padding:9px 16px; border-bottom:1px solid rgba(196,154,26,0.05); color:var(--text); }
  tr:last-child td { border-bottom:none; }
  tr:hover td { background:rgba(196,154,26,0.03); }
  .up { color:var(--green); }
  .down { color:var(--red); }
  .neutral { color:var(--text-dim); }
  .bang-cell { color:var(--gold-bright); font-weight:600; font-size:0.86rem; }

  /* Tooltip */
  .tt { position:fixed; background:var(--surface); border:1px solid rgba(196,154,26,0.35); border-radius:8px; min-width:192px; pointer-events:none; opacity:0; transition:opacity 0.12s; z-index:1000; overflow:hidden; box-shadow:0 12px 40px rgba(0,0,0,0.7); }
  .tt.show { opacity:1; }
  .tt-hdr { background:var(--surface2); border-bottom:1px solid rgba(196,154,26,0.2); padding:9px 13px; }
  .tt-player { font-family:'Bebas Neue',sans-serif; font-size:1rem; color:var(--gold-bright); letter-spacing:1.5px; line-height:1; }
  .tt-date { font-family:'DM Mono',monospace; font-size:0.58rem; color:var(--text-dim); margin-top:2px; letter-spacing:1px; }
  .tt-body { padding:10px 13px; }
  .tt-row { display:flex; justify-content:space-between; align-items:center; padding:4px 0; border-bottom:1px solid rgba(196,154,26,0.08); }
  .tt-row:last-child { border-bottom:none; }
  .tt-metric { font-family:'DM Mono',monospace; font-size:0.62rem; letter-spacing:2px; color:var(--text-dim); text-transform:uppercase; }
  .tt-val { font-family:'DM Mono',monospace; font-size:0.86rem; font-weight:500; }
  .tt-val.up { color:var(--green); }
  .tt-val.down { color:var(--red); }
  .tt-val.neutral { color:var(--text); }
  .tt-val.gold { color:var(--gold-bright); font-size:0.95rem; font-weight:700; }
  .tt-div { height:1px; background:rgba(196,154,26,0.15); margin:3px 0; }
</style>
</head>
<body>
<header>
  <div class="logo">
    <div class="badge">SD</div>
    <div>
      <h1>BANG Scores<span>Lake Elsinore Storm · 2026</span></h1>
    </div>
  </div>
  <div class="hdr-right">SWD · xWOBA · RC<br>Interactive Dashboard</div>
</header>

<div class="main">
  <div class="selector-row">
    <span class="sel-label">View</span>
    <button class="pbtn active" onclick="sel('Storm')">⚡ Storm</button>
    <button class="pbtn" onclick="sel('Bilecki, George')">Bilecki</button>
    <button class="pbtn" onclick="sel('Cantwell, Luke')">Cantwell</button>
    <button class="pbtn" onclick="sel('Cross, Kerrington')">Cross</button>
    <button class="pbtn" onclick="sel('DeCriscio, Justin')">DeCriscio</button>
    <button class="pbtn" onclick="sel('Duarte, Victor')">Duarte</button>
    <button class="pbtn" onclick="sel('Fountain, Kale')">Fountain</button>
    <button class="pbtn" onclick="sel('Frye, Bradley')">Frye</button>
    <button class="pbtn" onclick="sel('Harvey, Ty')">Harvey</button>
    <button class="pbtn" onclick="sel('Madonna, Truitt')">Madonna</button>
    <button class="pbtn" onclick="sel('Quintana, Jorge')">Quintana</button>
    <button class="pbtn" onclick="sel('Verdugo, Jose')">Verdugo</button>
    <button class="pbtn" onclick="sel('Westenburg, Conner')">Westenburg</button>
    <button class="pbtn" onclick="sel('Wideman, Ryan')">Wideman</button>
  </div>

  <div class="chart-section">
    <div class="chart-title" id="chartTitle">Storm</div>
    <div class="chart-sub">BANG Score Trend — Hover data points for SWD / xWOBA / RC breakdown</div>
    <div class="chart-wrap"><canvas id="chart"></canvas></div>
  </div>

  <div class="stats-bar">
    <div class="stat-card"><div class="stat-label">Season Avg</div><div class="stat-val" id="sAvg">--</div><div class="stat-sub">BANG Score</div></div>
    <div class="stat-card"><div class="stat-label">Season High</div><div class="stat-val" id="sHigh">--</div><div class="stat-sub">BANG Score</div></div>
    <div class="stat-card"><div class="stat-label">Season Low</div><div class="stat-val" id="sLow">--</div><div class="stat-sub">BANG Score</div></div>
    <div class="stat-card"><div class="stat-label">Games Played</div><div class="stat-val" id="sGames">--</div><div class="stat-sub">This Season</div></div>
  </div>

  <div class="log-section">
    <div class="log-hdr"><span class="log-title">Game Log</span></div>
    <table>
      <thead><tr><th>Date</th><th>SWD</th><th>xWOBA</th><th>RC</th><th>BANG</th></tr></thead>
      <tbody id="logBody"></tbody>
    </table>
  </div>
</div>

<div class="tt" id="tt">
  <div class="tt-hdr">
    <div class="tt-player" id="ttP"></div>
    <div class="tt-date" id="ttD"></div>
  </div>
  <div class="tt-body">
    <div class="tt-row"><span class="tt-metric">SWD</span><span class="tt-val" id="ttSWD"></span></div>
    <div class="tt-row"><span class="tt-metric">xWOBA</span><span class="tt-val" id="ttXW"></span></div>
    <div class="tt-row"><span class="tt-metric">RC</span><span class="tt-val" id="ttRC"></span></div>
    <div class="tt-div"></div>
    <div class="tt-row"><span class="tt-metric">BANG</span><span class="tt-val gold" id="ttB"></span></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
