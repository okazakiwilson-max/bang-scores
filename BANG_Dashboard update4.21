  'Quintana, Jorge':{'4/2/2026':{swd:55,xwoba:92,rc:85,bang:76},'4/4/2026':{swd:90,xwoba:56,rc:35,bang:65},'4/7/2026':{swd:49,xwoba:12,rc:1,bang:25},'4/9/2026':{swd:73,xwoba:67,rc:85,bang:73},'4/10/2026':{swd:80,xwoba:16,rc:4,bang:39},'4/11/2026':{swd:73,xwoba:25,rc:58,bang:51},'4/12/2026':{swd:59,xwoba:35,rc:46,bang:47},'4/14/2026':{swd:50,xwoba:17,rc:7,bang:28},'4/16/2026':{swd:42,xwoba:63,rc:41,bang:50},'4/17/2026':{swd:5,xwoba:14,rc:14,bang:10},'4/18/2026':{swd:47,xwoba:70,rc:50,bang:57},'4/19/2026':{swd:79,xwoba:78,rc:66,bang:76},'4/21/2026':{swd:72,xwoba:93,rc:72,bang:80}},
  'Verdugo, Jose':{'4/2/2026':{swd:34,xwoba:86,rc:73,bang:63},'4/3/2026':{swd:61,xwoba:91,rc:71,bang:75},'4/4/2026':{swd:30,xwoba:45,rc:33,bang:37},'4/7/2026':{swd:31,xwoba:38,rc:41,bang:36},'4/10/2026':{swd:56,xwoba:51,rc:21,bang:47},'4/11/2026':{swd:60,xwoba:26,rc:3,bang:35},'4/12/2026':{swd:81,xwoba:62,rc:58,bang:69},'4/15/2026':{swd:18,xwoba:12,rc:20,bang:16},'4/16/2026':{swd:7,xwoba:45,rc:79,bang:37},'4/18/2026':{swd:33,xwoba:36,rc:25,bang:33},'4/19/2026':{swd:51,xwoba:12,rc:28,bang:31},'4/21/2026':{swd:34,xwoba:17,rc:63,bang:33}},
  'Westenburg, Conner':{'4/2/2026':{swd:6,xwoba:51,rc:72,bang:37},'4/3/2026':{swd:50,xwoba:20,rc:15,bang:31},'4/7/2026':{swd:28,xwoba:22,rc:79,bang:36},'4/9/2026':{swd:63,xwoba:62,rc:96,bang:69},'4/10/2026':{swd:87,xwoba:96,rc:96,bang:92},'4/11/2026':{swd:38,xwoba:52,rc:46,bang:45},'4/12/2026':{swd:66,xwoba:80,rc:98,bang:78},'4/14/2026':{swd:46,xwoba:71,rc:85,bang:64},'4/15/2026':{swd:1,xwoba:15,rc:2,bang:7},'4/16/2026':{swd:6,xwoba:33,rc:38,bang:23},'4/18/2026':{swd:11,xwoba:7,rc:7,bang:9},'4/21/2026':{swd:90,xwoba:65,rc:91,bang:80}},
  'Wideman, Ryan':{'4/2/2026':{swd:58,xwoba:95,rc:98,bang:81},'4/3/2026':{swd:5,xwoba:4,rc:7,bang:5},'4/4/2026':{swd:45,xwoba:72,rc:70,bang:61},'4/7/2026':{swd:92,xwoba:59,rc:74,bang:75},'4/8/2026':{swd:55,xwoba:14,rc:18,bang:31},'4/9/2026':{swd:84,xwoba:76,rc:78,bang:80},'4/10/2026':{swd:68,xwoba:82,rc:17,bang:63},'4/11/2026':{swd:6,xwoba:62,rc:50,bang:37},'4/12/2026':{swd:41,xwoba:34,rc:97,bang:49},'4/14/2026':{swd:9,xwoba:11,rc:0,bang:8},'4/15/2026':{swd:41,xwoba:9,rc:5,bang:21},'4/16/2026':{swd:80,xwoba:89,rc:97,bang:87},'4/17/2026':{swd:95,xwoba:28,rc:57,bang:61},'4/18/2026':{swd:73,xwoba:36,rc:22,bang:48},'4/19/2026':{swd:73,xwoba:50,rc:31,bang:55},'4/21/2026':{swd:46,xwoba:89,rc:99,bang:74}},
};

let current = 'Storm';
let myChart = null;

function trend(cur, prev) {
  if (prev === null || prev === undefined) return 'neutral';
  return cur > prev ? 'up' : cur < prev ? 'down' : 'neutral';
}

function arrow(t) {
  return t === 'up' ? ' ↑' : t === 'down' ? ' ↓' : '';
}

function sel(name) {
  current = name;
  document.querySelectorAll('.pbtn').forEach(b => {
    b.classList.toggle('active', b.getAttribute('onclick') === `sel('${name}')`);
  });
  update();
}

function update() {
  const pd = DATA[current] || {};
  const gd = DATES.filter(d => pd[d]);
  const scores = gd.map(d => pd[d].bang);

  document.getElementById('chartTitle').textContent = current;

  if (scores.length) {
    const avg = (scores.reduce((a,b)=>a+b,0)/scores.length).toFixed(1);
    document.getElementById('sAvg').textContent = avg;
    document.getElementById('sHigh').textContent = Math.max(...scores);
    document.getElementById('sLow').textContent = Math.min(...scores);
    document.getElementById('sGames').textContent = scores.length;
  }

  if (myChart) myChart.destroy();
  const ctx = document.getElementById('chart').getContext('2d');
  myChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: gd.map(d => d.replace('/2026','')),
      datasets: [{
        data: scores,
        borderColor: '#c49a1a',
        backgroundColor: 'rgba(196,154,26,0.06)',
        borderWidth: 2.5,
        pointBackgroundColor: '#c49a1a',
        pointBorderColor: '#1a1612',
        pointBorderWidth: 2,
        pointRadius: 6,
        pointHoverRadius: 9,
        tension: 0.3,
        fill: true,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: {display:false}, tooltip: {enabled:false} },
      scales: {
        x: { grid:{color:'rgba(255,196,37,0.06)'}, ticks:{color:'rgba(245,240,224,0.45)',font:{family:'DM Mono',size:10}} },
        y: { min:0, max:100, grid:{color:'rgba(255,196,37,0.06)'}, ticks:{color:'rgba(245,240,224,0.45)',font:{family:'DM Mono',size:10},stepSize:20} }
      },
      onHover: (evt, els) => {
        if (els.length) showTT(evt, gd[els[0].index], els[0].index, gd);
        else hideTT();
      }
    }
  });

  // Game log
  const tbody = document.getElementById('logBody');
  tbody.innerHTML = '';
  gd.forEach((date, i) => {
    const cur = pd[date];
    const prev = i > 0 ? pd[gd[i-1]] : null;
    const tr = document.createElement('tr');
    let html = `<td style="font-size:0.7rem;opacity:0.55">${date.replace('/2026','')}</td>`;
    ['swd','xwoba','rc'].forEach(m => {
      const t = prev ? trend(cur[m], prev[m]) : 'neutral';
      html += `<td class="${t}">${cur[m]}${arrow(t)}</td>`;
    });
    html += `<td class="bang-cell">${cur.bang}</td>`;
    tr.innerHTML = html;
    tbody.appendChild(tr);
  });
}

function showTT(evt, date, idx, gd) {
  const pd = DATA[current];
  const cur = pd[date];
  const prev = idx > 0 ? pd[gd[idx-1]] : null;

  document.getElementById('ttP').textContent = current;
  document.getElementById('ttD').textContent = date;

  [['ttSWD','swd'],['ttXW','xwoba'],['ttRC','rc']].forEach(([id, m]) => {
    const el = document.getElementById(id);
    const t = prev ? trend(cur[m], prev[m]) : 'neutral';
    el.className = `tt-val ${t}`;
    el.textContent = cur[m] + arrow(t);
  });
  document.getElementById('ttB').textContent = cur.bang;

  const tt = document.getElementById('tt');
  tt.classList.add('show');
  const x = evt.native.clientX + 16;
  const y = evt.native.clientY - 90;
  tt.style.left = Math.min(x, window.innerWidth - 210) + 'px';
  tt.style.top = Math.max(y, 10) + 'px';
}

function hideTT() {
  document.getElementById('tt').classList.remove('show');
}

update();
document.getElementById('chart').addEventListener('mouseleave', hideTT);
</script>
</body>
</html>
